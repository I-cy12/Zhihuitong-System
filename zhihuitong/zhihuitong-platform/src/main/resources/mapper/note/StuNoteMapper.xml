<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhihuitong.note.mapper.StuNoteMapper">
    
    <resultMap type="StuNote" id="StuNoteResult">
        <result property="id"    column="id"    />
        <result property="studentId"    column="student_id"    />
        <result property="courseId"    column="course_id"    />
        <result property="courseNameSnapshot"    column="course_name_snapshot"    />
        <result property="title"    column="title"    />
        <result property="content"    column="content"    />
        <result property="tags"    column="tags"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
        <result property="coverImage"    column="cover_image"    />
    </resultMap>

    <sql id="selectStuNoteVo">
        select id, student_id, course_id, course_name_snapshot, title, content, tags, created_at, updated_at, cover_image from stu_note
    </sql>

    <select id="selectStuNoteList" parameterType="StuNote" resultMap="StuNoteResult">
        <include refid="selectStuNoteVo"/>
        <where>  
            <if test="studentId != null "> and student_id = #{studentId}</if>
            <if test="courseId != null "> and course_id = #{courseId}</if>
            <if test="courseNameSnapshot != null  and courseNameSnapshot != ''"> and course_name_snapshot like concat('%', #{courseNameSnapshot}, '%')</if>
            <if test="title != null  and title != ''"> and title like concat('%', #{title}, '%')</if>
            <if test="content != null  and content != ''"> and content like concat('%', #{content}, '%')</if>
            <if test="tags != null  and tags != ''"> and tags like concat('%', #{tags}, '%')</if>
            <if test="createdAt != null "> and created_at like concat('%', #{createdAt}, '%')</if>
            <if test="updatedAt != null "> and updated_at = #{updatedAt}</if>
            <if test="coverImage != null  and coverImage != ''"> and cover_image = #{coverImage}</if>
        </where>
    </select>
    
    <select id="selectStuNoteById" parameterType="Long" resultMap="StuNoteResult">
        <include refid="selectStuNoteVo"/>
        where id = #{id}
    </select>

    <insert id="insertStuNote" parameterType="StuNote" useGeneratedKeys="true" keyProperty="id">
        insert into stu_note
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="studentId != null">student_id,</if>
            <if test="courseId != null">course_id,</if>
            <if test="courseNameSnapshot != null and courseNameSnapshot != ''">course_name_snapshot,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="tags != null and tags != ''">tags,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
            <if test="coverImage != null">cover_image,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="studentId != null">#{studentId},</if>
            <if test="courseId != null">#{courseId},</if>
            <if test="courseNameSnapshot != null and courseNameSnapshot != ''">#{courseNameSnapshot},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="tags != null and tags != ''">#{tags},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
            <if test="coverImage != null">#{coverImage},</if>
         </trim>
    </insert>

    <update id="updateStuNote" parameterType="StuNote">
        update stu_note
        <trim prefix="SET" suffixOverrides=",">
            <if test="studentId != null">student_id = #{studentId},</if>
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="courseNameSnapshot != null and courseNameSnapshot != ''">course_name_snapshot = #{courseNameSnapshot},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="tags != null and tags != ''">tags = #{tags},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStuNoteById" parameterType="Long">
        delete from stu_note where id = #{id}
    </delete>

    <delete id="deleteStuNoteByIds" parameterType="String">
        delete from stu_note where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>