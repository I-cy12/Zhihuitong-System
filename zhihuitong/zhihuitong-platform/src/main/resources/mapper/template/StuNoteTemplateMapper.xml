<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhihuitong.template.mapper.StuNoteTemplateMapper">
    
    <resultMap type="StuNoteTemplate" id="StuNoteTemplateResult">
        <result property="id"    column="id"    />
        <result property="studentId"    column="student_id"    />
        <result property="name"    column="name"    />
        <result property="type"    column="type"    />
        <result property="content"    column="content"    />
        <result property="sortNo"    column="sort_no"    />
        <result property="status"    column="status"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <sql id="selectStuNoteTemplateVo">
        select id, student_id, name, type, content, sort_no, status, created_at, updated_at from stu_note_template
    </sql>

    <select id="selectStuNoteTemplateList" parameterType="StuNoteTemplate" resultMap="StuNoteTemplateResult">
        <include refid="selectStuNoteTemplateVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
        </where>
    </select>
    
    <select id="selectStuNoteTemplateById" parameterType="Long" resultMap="StuNoteTemplateResult">
        <include refid="selectStuNoteTemplateVo"/>
        where id = #{id}
    </select>

    <insert id="insertStuNoteTemplate" parameterType="StuNoteTemplate" useGeneratedKeys="true" keyProperty="id">
        insert into stu_note_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="studentId != null">student_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="type != null and type != ''">type,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="sortNo != null">sort_no,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="studentId != null">#{studentId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="type != null and type != ''">#{type},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="sortNo != null">#{sortNo},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
         </trim>
    </insert>

    <update id="updateStuNoteTemplate" parameterType="StuNoteTemplate">
        update stu_note_template
        <trim prefix="SET" suffixOverrides=",">
            <if test="studentId != null">student_id = #{studentId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="type != null and type != ''">type = #{type},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="sortNo != null">sort_no = #{sortNo},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStuNoteTemplateById" parameterType="Long">
        delete from stu_note_template where id = #{id}
    </delete>

    <delete id="deleteStuNoteTemplateByIds" parameterType="String">
        delete from stu_note_template where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>